    "peekViewEditor.background": "#181818",
    "peekViewResult.background": "#151515",
    "peekViewTitle.background": "#1b1b1b"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6d757f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "meta.import keyword",
        "meta.import punctuation.definition.keyword",
        "meta.export keyword"
      ],
      "settings": {
        "foreground": "#d6b4ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Imported type names",
      "scope": [
        "meta.import entity.name.type",
        "meta.import support.class",
        "meta.import support.type",
        "meta.import entity.name.class",
        "meta.import variable.other.readwrite",
        "meta.import variable.other.object",
        "meta.import meta.brace variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#92bcff"
      }
    },
    {
      "name": "Import paths",
      "scope": [
        "meta.import string",
        "meta.import string.quoted",
        "meta.import punctuation.definition.string.begin",
        "meta.import punctuation.definition.string.end",
        "meta.export string",
        "meta.export string.quoted",
        "meta.export punctuation.definition.string.begin",
        "meta.export punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#9edcc7"
      }
    },
    {
      "name": "Import braces",
      "scope": [
        "meta.import meta.brace",
        "meta.import punctuation.section.embedded.begin",
        "meta.import punctuation.section.embedded.end",
        "meta.import punctuation.definition.generic.begin",
        "meta.import punctuation.definition.generic.end"
      ],
      "settings": {
        "foreground": "#82d0f2"
      }
    },
    {
      "name": "Brackets and delimiters",
      "scope": [
        "punctuation.section.block.begin",
        "punctuation.section.block.end",
        "punctuation.section.group.begin",
        "punctuation.section.group.end",
        "punctuation.section.parens.begin",
        "punctuation.section.parens.end",
        "punctuation.section.brackets.begin",
        "punctuation.section.brackets.end",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.definition.arguments.begin",
        "punctuation.definition.arguments.end",
        "punctuation.definition.array.begin",
        "punctuation.definition.array.end",
        "punctuation.definition.block.begin",
        "punctuation.definition.block.end",
        "source.js punctuation.section",
        "source.ts punctuation.section",
        "source.jsx punctuation.section",
        "source.tsx punctuation.section",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#ffd15f"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#d6b4ff"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#92bcff"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#92bcff"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "identifier", "support.variable"],
      "settings": {
        "foreground": "#bec8d4"
      }
    },
    {
      "name": "JavaScript and TypeScript properties",
      "scope": [
        "source.js variable.other.property",
        "source.ts variable.other.property",
        "source.jsx variable.other.property",
        "source.tsx variable.other.property",
        "meta.object-literal.key",
        "meta.object.member variable.other.property",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#d7e3f0"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c3caff"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9edcc7"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#ffd15f"
      }
    },
    {
      "name": "HTML tags",
      "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#82d0f2"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "text.html entity.other.attribute-name",
        "text.html.basic entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c3caff"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "source.css support.type.property-name",
        "source.scss support.type.property-name",
        "source.sass support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#92bcff"
      }
    },
    {
      "name": "CSS values and units",
      "scope": [
        "source.css constant.numeric",
        "source.scss constant.numeric",
        "source.sass constant.numeric",
        "source.less constant.numeric",
        "source.stylus constant.numeric",
        "source.postcss constant.numeric",
        "source.css keyword.other.unit",
        "source.scss keyword.other.unit",
        "source.sass keyword.other.unit",
        "source.less keyword.other.unit",
        "source.stylus keyword.other.unit",
        "source.postcss keyword.other.unit",
        "source.css support.constant",
        "source.scss support.constant",
        "source.sass support.constant",
        "source.less support.constant",
        "source.stylus support.constant",
        "source.postcss support.constant"
      ],
      "settings": {
        "foreground": "#aad0c6"
      }
    },
    {
      "name": "Generic attributes and properties",
      "scope": ["entity.other.attribute-name", "support.type.property-name"],
      "settings": {
        "foreground": "#a6adc8"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#919ca8"
      }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#92bcff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown emphasis",
      "scope": ["markup.bold", "markup.italic"],
      "settings": {
        "foreground": "#c7d1dc"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": {
        "foreground": "#9edcc7"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": {
        "foreground": "#d46f6f"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#d46f6f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c3caff",
    "class": "#c3caff",
    "enum": "#c3caff",
    "interface": "#c3caff",
    "type": "#c3caff",
    "typeParameter": "#92bcff",
    "struct": "#c3caff",
    "parameter": "#92bcff",
    "variable": "#bec8d4",
    "property": "#d7e3f0",
    "enumMember": "#ffd15f",
    "event": "#92bcff",
    "function": "#92bcff",
    "method": "#92bcff",
    "macro": "#d6b4ff",
    "keyword": "#d6b4ff",
    "modifier": "#d6b4ff",
    "comment": {
      "foreground": "#6d757f",
      "fontStyle": "italic"
    },
    "string": "#9edcc7",
    "number": "#ffd15f",
    "regexp": "#82d0f2",
    "operator": "#919ca8",
    "decorator": "#ffd15f"
  }
}
