{
  "name": "Omakase Kuroshio",
  "type": "dark",
  "colors": {
    // Global
    "focusBorder": "#151515",
    "selection.background": "#2B3A50",
    "textLink.foreground": "#90B8F5",
    "textBlockQuote.background": "#181818",
    "textBlockQuote.border": "#2b2b2b",
    "textCodeBlock.background": "#161616",
    "window.activeBorder": "#000000",
    "window.inactiveBorder": "#000000",
    "editor.selectionHighlightBackground": "#3A4F6A66",
    // Editor
    "editor.background": "#181818",
    "editor.foreground": "#CDD6E3",
    "editorLineNumber.foreground": "#444444",
    "editorCursor.foreground": "#90B8F5",
    "editor.selectionBackground": "#2B3A50",
    "editor.findMatchHighlightBackground": "#3A4F6A66",
    "editor.lineHighlightBackground": "#1b1b1b",
    "editor.wordHighlightBackground": "#45587944",
    "editor.wordHighlightStrongBackground": "#5d79a544",
    // Editor: Indentation & Brackets
    "editorIndentGuide.background1": "#2A2F34",
    "editorIndentGuide.activeBackground1": "#3F5470",
    "editorBracketMatch.border": "#8FB8F566",
    "editorBracketHighlight.foreground1": "#7FE7D0",
    "editorBracketHighlight.foreground2": "#919CA8",
    "editorBracketHighlight.foreground3": "#C7A8FF",
    "editorBracketHighlight.foreground4": "#7FE7D0",
    "editorBracketHighlight.foreground5": "#919CA8",
    "editorBracketHighlight.foreground6": "#BED4FB",
    // Editor: Diagnostics
    "editorError.foreground": "#E06C75",
    "editorWarning.foreground": "#E6A65D",
    "editorInfo.foreground": "#8FB8F5",
    "editorHint.foreground": "#7FE7D0",
    // Editor: Gutter
    "editorGutter.addedBackground": "#7FD8C3",
    "editorGutter.modifiedBackground": "#8FB8F5",
    "editorGutter.deletedBackground": "#D46F6F",
    // Editor: Overview Ruler
    "editorOverviewRuler.errorForeground": "#E06C75B3",
    "editorOverviewRuler.warningForeground": "#E6A65DB3",
    "editorOverviewRuler.infoForeground": "#8FB8F5B3",
    // Editor: Widgets
    "editorWidget.background": "#1B1B1B",
    "editorWidget.border": "#2A2A2A",
    "editorSuggestWidget.background": "#1B1B1B",
    "editorSuggestWidget.border": "#2A2A2A",
    "editorSuggestWidget.foreground": "#BEC8D4",
    "editorSuggestWidget.highlightForeground": "#8FB8F5",
    "editorSuggestWidget.selectedBackground": "#25282D",
    "editorHoverWidget.background": "#1B1B1B",
    "editorHoverWidget.border": "#2A2A2A",
    // Editor Groups & Tabs
    "editorGroupHeader.tabsBackground": "#141414",
    "editorGroup.border": "#202020",
    "tab.activeBackground": "#1C1C1C",
    "tab.inactiveBackground": "#141414",
    "tab.inactiveForeground": "#7F8893",
    "tab.border": "#141414",
    "tab.activeBorder": "#63B9AE",
    "tab.activeModifiedBorder": "#8FB8F5",
    "tab.inactiveModifiedBorder": "#6F8FBF",
    // Activity Bar
    "activityBar.background": "#151515",
    "activityBar.foreground": "#C7D1DC",
    "activityBar.inactiveForeground": "#6F7781",
    "activityBarBadge.background": "#8FB8F5",
    "activityBarBadge.foreground": "#181818",
    // Sidebar
    "sideBar.background": "#151515",
    "sideBarTitle.foreground": "#CCD6E1",
    "sideBarSectionHeader.background": "#1A1A1A",
    "sideBarSectionHeader.foreground": "#C1CBD7",
    // List & Trees
    "list.activeSelectionBackground": "#25282D",
    "list.activeSelectionForeground": "#D3DDE8",
    "list.hoverBackground": "#1F2125",
    "list.hoverForeground": "#CFD8E3",
    "list.inactiveSelectionBackground": "#1E2024",
    "list.highlightForeground": "#8FB8F5",
    // Panel
    "panel.background": "#141414",
    "panel.border": "#202020",
    "panelTitle.activeForeground": "#D0DAE5",
    "panelTitle.inactiveForeground": "#858D97",
    // Terminal
    "terminal.background": "#181818",
    "terminal.foreground": "#BEC8D4",
    "terminalCursor.foreground": "#C8D6E5",
    "terminal.ansiBlack": "#181818",
    "terminal.ansiRed": "#D46F6F",
    "terminal.ansiGreen": "#7FE7D0",
    "terminal.ansiYellow": "#7BCFC0",
    "terminal.ansiBlue": "#8FB8F5",
    "terminal.ansiMagenta": "#BBA7E8",
    "terminal.ansiCyan": "#82D0F2",
    "terminal.ansiWhite": "#BEC8D4",
    "terminal.ansiBrightBlack": "#68717B",
    "terminal.ansiBrightRed": "#DF8A8A",
    "terminal.ansiBrightGreen": "#A7F2E1",
    "terminal.ansiBrightYellow": "#9EDFD3",
    "terminal.ansiBrightBlue": "#BED4FB",
    "terminal.ansiBrightMagenta": "#D7C9F4",
    "terminal.ansiBrightCyan": "#C2E9F8",
    "terminal.ansiBrightWhite": "#D6DFEA",
    // Status Bar
    "statusBar.background": "#151515",
    "statusBar.foreground": "#BEC8D4",
    "statusBar.border": "#202020",
    "statusBar.debuggingBackground": "#8FB8F5",
    "statusBar.debuggingForeground": "#181818",
    "statusBar.noFolderBackground": "#151515",
    "statusBarItem.hoverBackground": "#23262B",
    // Title Bar
    "titleBar.activeBackground": "#141414",
    "titleBar.activeForeground": "#CBD5E0",
    "titleBar.inactiveBackground": "#141414",
    "titleBar.inactiveForeground": "#7E8792",
    // Menu
    "menu.background": "#1A1A1A",
    "menu.foreground": "#BEC8D4",
    "menu.selectionBackground": "#25282D",
    "menu.selectionForeground": "#D1DBE6",
    // Input & Dropdown
    "input.background": "#1B1B1B",
    "input.foreground": "#C7D1DC",
    "input.border": "#2A2A2A",
    "input.placeholderForeground": "#7A838D",
    "inputOption.activeBorder": "#8FB8F5",
    "dropdown.background": "#1B1B1B",
    "dropdown.foreground": "#C7D1DC",
    "dropdown.border": "#2A2A2A",
    // Button & Checkbox
    "button.background": "#355078",
    "button.foreground": "#E0EAF5",
    "button.hoverBackground": "#41608A",
    "checkbox.background": "#1B1B1B",
    "checkbox.border": "#343434",
    // Badge
    "badge.background": "#304055",
    "badge.foreground": "#DCE7F3",
    // Breadcrumb
    "breadcrumb.foreground": "#89919C",
    "breadcrumb.focusForeground": "#CDD7E2",
    "breadcrumb.activeSelectionForeground": "#CDD7E2",
    // Minimap
    "minimap.background": "#181818",
    "minimap.selectionHighlight": "#2D3238CC",
    "minimap.findMatchHighlight": "#879FD066",
    // Scrollbar
    "scrollbarSlider.background": "#33333377",
    "scrollbarSlider.hoverBackground": "#42424299",
    "scrollbarSlider.activeBackground": "#51515199",
    // Git Decorations
    "gitDecoration.addedResourceForeground": "#7FE7D0",
    "gitDecoration.modifiedResourceForeground": "#8FB8F5",
    "gitDecoration.deletedResourceForeground": "#D46F6F",
    "gitDecoration.untrackedResourceForeground": "#9FCDBF",
    // Diff Editor
    "diffEditor.insertedTextBackground": "#22312D88",
    "diffEditor.removedTextBackground": "#41282888",
    // Peek View
    "peekView.border": "#2A2A2A",
    "peekViewEditor.background": "#181818",
    "peekViewResult.background": "#151515",
    "peekViewTitle.background": "#1B1B1B"
  },
  "tokenColors": [
    // Comments
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6d757f",
        "fontStyle": "italic"
      }
    },

    // Variables
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": ["meta.block variable.other"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": ["support.other.variable", "string.other.link"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Language methods",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },

    // Keywords & Storage
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },

    // Functions & Classes
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": ["entity.name.method.js"],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#90B8F5"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "foreground": "#76D4C3"
      }
    },

    // Strings & Constants
    {
      "name": "String, Symbols, Inherited Class",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Number, Constant, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "support.constant",
        "constant.character",
        "constant.escape",
        "keyword.other.unit",
        "keyword.other",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Colors",
      "scope": ["constant.other.color"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },

    // HTML
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#90B8F5"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#AEBCCD"
      }
    },

    // CSS
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name",
        "support.type.vendored.property-name.css",
        "source.css.scss entity.name.tag",
        "variable.parameter.keyframe-list.css",
        "meta.property-name.css",
        "variable.parameter.url.scss",
        "meta.property-value.scss",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#E6EDF5"
      }
    },
    {
      "name": "CSS Classes",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "meta.attribute-selector.scss",
        "variable.parameter.misc.css"
      ],
      "settings": {
        "foreground": "#93BCF4"
      }
    },
    {
      "name": "CSS ID's",
      "scope": ["source.sass keyword.control", "meta.attribute-selector.scss"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.property-list.scss",
        "meta.attribute-selector.scss",
        "meta.property-value.css",
        "entity.other.keyframe-offset.css",
        "meta.selector.css",
        "entity.name.tag.reference.scss",
        "entity.name.tag.nesting.css",
        "punctuation.separator.key-value.css"
      ],
      "settings": {
        "foreground": "#AEBCCD"
      }
    },

    // JSON
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#90B8F5"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#76D4C3"
      }
    },
    {
      "name": "JSON Key - Level 3+",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },

    // Markdown
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown",
        "markup.heading",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": ["markup.bold", "markup.bold string"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold italic",
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#90B8F5"
      }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": ["markup.quote punctuation.definition.blockquote.markdown"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markup - Quote",
      "scope": ["markup.quote"]
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": ["string.other.link.title.markdown"],
      "settings": {
        "foreground": "#90B8F5"
      }
    },
    {
      "name": "Markdown - Link Description",
      "scope": ["string.other.link.description.title.markdown"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": ["constant.other.reference.link.markdown"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Markup - Raw Block",
      "scope": ["markup.raw.block"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "Markdown - Fenced Block",
      "scope": [
        "markup.raw.block.fenced.markdown",
        "variable.language.fenced.markdown",
        "punctuation.definition.fenced.markdown",
        "punctuation.section.class.end"
      ],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markdown - Fenced Language",
      "scope": ["variable.language.fenced.markdown"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Markdown - Separator",
      "scope": ["meta.separator"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#6d757f"
      }
    },
    {
      "name": "Markup - Table",
      "scope": ["markup.table"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },

    // Diff
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#D46F6F"
      }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },

    // Misc
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#D46F6F"
      }
    },

    // Invalid
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#E06C75"
      }
    }
  ]
}
