{
  "name": "Omakase Kuroshio",
  "type": "dark",
  "$schema": "vscode://schemas/color-theme",

  "colors": {
    "focusBorder": "#151515",
    "selection.background": "#2B3A50",
    "textLink.foreground": "#6DAAFF",
    "textBlockQuote.background": "#181818",
    "textBlockQuote.border": "#2b2b2b",
    "textCodeBlock.background": "#161616",
    "window.activeBorder": "#000000",
    "window.inactiveBorder": "#000000",
    "editor.selectionHighlightBackground": "#2E3F5566",
    "editor.background": "#181818",
    "editor.foreground": "#B8CCDA",
    "editorLineNumber.foreground": "#3A4550",
    "editorCursor.foreground": "#6DAAFF",
    "editor.selectionBackground": "#2B3A50",
    "editor.findMatchHighlightBackground": "#3A4F6A55",
    "editor.lineHighlightBackground": "#1b1b1b",
    "editor.wordHighlightBackground": "#2A3F5544",
    "editor.wordHighlightStrongBackground": "#35506644",
    "editorIndentGuide.background1": "#232830",
    "editorIndentGuide.activeBackground1": "#2E4058",
    "editorBracketMatch.border": "#6DAAFF66",
    "editorBracketHighlight.foreground1": "#7FE7D0",
    "editorBracketHighlight.foreground2": "#4EC9E4",
    "editorBracketHighlight.foreground3": "#9D8FD8",
    "editorBracketHighlight.foreground4": "#7FE7D0",
    "editorBracketHighlight.foreground5": "#50B0C4",
    "editorBracketHighlight.foreground6": "#6DAAFF",
    "editorError.foreground": "#E06C75",
    "editorWarning.foreground": "#E0924A",
    "editorInfo.foreground": "#6DAAFF",
    "editorHint.foreground": "#7FE7D0",
    "editorGutter.addedBackground": "#4E9E8A",
    "editorGutter.modifiedBackground": "#6DAAFF",
    "editorGutter.deletedBackground": "#A05060",
    "editorOverviewRuler.errorForeground": "#E06C75B3",
    "editorOverviewRuler.warningForeground": "#E0924AB3",
    "editorOverviewRuler.infoForeground": "#6DAAFFB3",
    "editorWidget.background": "#1B1B1B",
    "editorWidget.border": "#252A30",
    "editorSuggestWidget.background": "#1B1B1B",
    "editorSuggestWidget.border": "#252A30",
    "editorSuggestWidget.foreground": "#A8BFCF",
    "editorSuggestWidget.highlightForeground": "#6DAAFF",
    "editorSuggestWidget.selectedBackground": "#22272E",
    "editorHoverWidget.background": "#1B1B1B",
    "editorHoverWidget.border": "#252A30",
    "editorGroupHeader.tabsBackground": "#141414",
    "editorGroup.border": "#1E2228",
    "tab.activeBackground": "#1C1C1C",
    "tab.inactiveBackground": "#141414",
    "tab.inactiveForeground": "#4E6070",
    "tab.border": "#141414",
    "tab.activeBorder": "#4EC9E4",
    "tab.activeModifiedBorder": "#6DAAFF",
    "tab.inactiveModifiedBorder": "#5A6F88",
    "activityBar.background": "#151515",
    "activityBar.foreground": "#A8BFD0",
    "activityBar.inactiveForeground": "#3A4E60",
    "activityBarBadge.background": "#6DAAFF",
    "activityBarBadge.foreground": "#181818",
    "sideBar.background": "#151515",
    "sideBarTitle.foreground": "#8AABB8",
    "sideBarSectionHeader.background": "#1A1A1A",
    "sideBarSectionHeader.foreground": "#7A9AAE",
    "list.activeSelectionBackground": "#22272E",
    "list.activeSelectionForeground": "#B8CCDA",
    "list.hoverBackground": "#1D2228",
    "list.hoverForeground": "#A8BFCF",
    "list.inactiveSelectionBackground": "#1E2228",
    "list.highlightForeground": "#6DAAFF",
    "panel.background": "#141414",
    "panel.border": "#1E2228",
    "panelTitle.activeForeground": "#A8BFCF",
    "panelTitle.inactiveForeground": "#4E6070",
    "terminal.background": "#181818",
    "terminal.foreground": "#A8BFCF",
    "terminalCursor.foreground": "#6DAAFF",
    "terminal.ansiBlack": "#181818",
    "terminal.ansiRed": "#A05060",
    "terminal.ansiGreen": "#7FE7D0",
    "terminal.ansiYellow": "#E0924A",
    "terminal.ansiBlue": "#6DAAFF",
    "terminal.ansiMagenta": "#A28CF4",
    "terminal.ansiCyan": "#4EC9E4",
    "terminal.ansiWhite": "#A8BFCF",
    "terminal.ansiBrightBlack": "#4E6070",
    "terminal.ansiBrightRed": "#C07080",
    "terminal.ansiBrightGreen": "#A7F2E1",
    "terminal.ansiBrightYellow": "#ECA86A",
    "terminal.ansiBrightBlue": "#9ABCFF",
    "terminal.ansiBrightMagenta": "#A89ED4",
    "terminal.ansiBrightCyan": "#7FD4E8",
    "terminal.ansiBrightWhite": "#C2D4E0",
    "statusBar.background": "#151515",
    "statusBar.foreground": "#7A9AAE",
    "statusBar.border": "#1E2228",
    "statusBar.debuggingBackground": "#6DAAFF",
    "statusBar.debuggingForeground": "#181818",
    "statusBar.noFolderBackground": "#151515",
    "statusBarItem.hoverBackground": "#22272E",
    "titleBar.activeBackground": "#141414",
    "titleBar.activeForeground": "#8AABB8",
    "titleBar.inactiveBackground": "#141414",
    "titleBar.inactiveForeground": "#3A4E60",
    "menu.background": "#1A1A1A",
    "menu.foreground": "#A8BFCF",
    "menu.selectionBackground": "#22272E",
    "menu.selectionForeground": "#B8CCDA",
    "input.background": "#1B1B1B",
    "input.foreground": "#A8BFCF",
    "input.border": "#252A30",
    "input.placeholderForeground": "#3A4E60",
    "inputOption.activeBorder": "#6DAAFF",
    "dropdown.background": "#1B1B1B",
    "dropdown.foreground": "#A8BFCF",
    "dropdown.border": "#252A30",
    "button.background": "#2A4068",
    "button.foreground": "#C8DCED",
    "button.hoverBackground": "#345080",
    "checkbox.background": "#1B1B1B",
    "checkbox.border": "#2E3840",
    "badge.background": "#253040",
    "badge.foreground": "#A8BFCF",
    "breadcrumb.foreground": "#4E6070",
    "breadcrumb.focusForeground": "#A8BFCF",
    "breadcrumb.activeSelectionForeground": "#A8BFCF",
    "minimap.background": "#181818",
    "minimap.selectionHighlight": "#2B3A50CC",
    "minimap.findMatchHighlight": "#3A5C8066",
    "scrollbarSlider.background": "#2A333C77",
    "scrollbarSlider.hoverBackground": "#354050AA",
    "scrollbarSlider.activeBackground": "#3E4E60AA",
    "gitDecoration.addedResourceForeground": "#4E9E8A",
    "gitDecoration.modifiedResourceForeground": "#6DAAFF",
    "gitDecoration.deletedResourceForeground": "#A05060",
    "gitDecoration.untrackedResourceForeground": "#4EC9E4",
    "diffEditor.insertedTextBackground": "#1E382E88",
    "diffEditor.removedTextBackground": "#38202088",
    "peekView.border": "#252A30",
    "peekViewEditor.background": "#181818",
    "peekViewResult.background": "#151515",
    "peekViewTitle.background": "#1B1B1B"
  },

  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4E6070", "fontStyle": "italic" }
    },

    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.readwrite.ts",
        "variable.other.readwrite.tsx",
        "meta.block variable.other",
        "support.other.variable",
        "string constant.other.placeholder"
      ],
      "settings": { "foreground": "#85AADF" }
    },
    {
      "name": "Object variable base",
      "scope": [
        "variable.other.object",
        "variable.other.object.ts",
        "variable.other.object.tsx"
      ],
      "settings": { "foreground": "#85AADF" }
    },
    {
      "name": "Object property access",
      "scope": [
        "variable.other.property",
        "variable.other.property.ts",
        "variable.other.property.tsx",
        "variable.other.object.property",
        "variable.other.object.property.ts",
        "variable.other.object.property.tsx",
        "support.variable.property",
        "meta.property-access variable",
        "meta.property-access entity.name",
        "entity.name.property"
      ],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#85AADF", "fontStyle": "italic" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.function",
        "meta.function.parameters variable.other",
        "meta.parameters variable.parameter"
      ],
      "settings": { "foreground": "#85AADF" }
    },

    {
      "name": "Storage type (const, let, var, class, function, async, type, void)",
      "scope": [
        "storage.type",
        "storage.modifier",
        "storage.type.ts",
        "keyword.type",
        "keyword.type.ts",
        "keyword.type.tsx"
      ],
      "settings": { "foreground": "#A28CF4" }
    },
    {
      "name": "Module keywords (import, export, from, as, default)",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": { "foreground": "#A28CF4" }
    },
    {
      "name": "Control flow (if, for, while, return, throw, try, catch)",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch",
        "keyword.control.switch"
      ],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "Keywords (general)",
      "scope": ["keyword"],
      "settings": { "foreground": "#A28CF4" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": { "foreground": "#607A90" }
    },
    {
      "name": "Type operators",
      "scope": [
        "keyword.operator.type",
        "keyword.operator.type.annotation",
        "keyword.operator.optional",
        "keyword.operator.nullable"
      ],
      "settings": { "foreground": "#5A7A90" }
    },
    {
      "name": "Punctuation section embedded",
      "scope": ["punctuation.section.embedded"],
      "settings": { "foreground": "#607A90" }
    },
    {
      "name": "Template expression brackets",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#7FE7D0" }
    },

    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": { "foreground": "#6DAAFF" }
    },
    {
      "name": "Method calls",
      "scope": [
        "entity.name.method.js",
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor",
        "entity.name.function.member"
      ],
      "settings": { "foreground": "#6DAAFF" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js",
        "meta.decorator",
        "meta.decorator punctuation.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#4EC9E4", "fontStyle": "italic" }
    },

    {
      "name": "Classes and named types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.ts",
        "entity.name.type.tsx",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "Support types and classes",
      "scope": [
        "support.class",
        "support.type",
        "support.type.primitive.ts",
        "support.type.builtin.ts",
        "support.type.builtin",
        "support.type.object.module",
        "support.type.sys-types"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "meta.type.parameters",
        "meta.type.declaration",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "entity.name (general fallback)",
      "scope": ["entity.name", "markup.changed.git_gutter"],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "Sub-methods and class refs (JS)",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },

    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "string.other.link",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#7FE7D0" }
    },

    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#9D8FD8" }
    },
    {
      "name": "Booleans and language constants",
      "scope": [
        "constant.language.boolean",
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": { "foreground": "#9D8FD8" }
    },
    {
      "name": "Support constants",
      "scope": ["support.constant"],
      "settings": { "foreground": "#9D8FD8" }
    },
    {
      "name": "Character constants",
      "scope": ["constant.character", "constant.escape"],
      "settings": { "foreground": "#9D8FD8" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "CSS numbers (override to match strings/units)",
      "scope": [
        "source.css constant.numeric",
        "source.scss constant.numeric",
        "source.sass constant.numeric",
        "source.less constant.numeric",
        "meta.property-value.css constant.numeric",
        "meta.property-value.scss constant.numeric"
      ],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "CSS hex colors",
      "scope": ["constant.other.color"],
      "settings": { "foreground": "#85AADF" }
    },
    {
      "name": "Other keywords",
      "scope": ["keyword.other"],
      "settings": { "foreground": "#A28CF4" }
    },

    {
      "name": "HTML / JSX tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": { "foreground": "#6DAEFF" }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx",
        "meta.jsx.prop.name",
        "meta.tsx.prop.name"
      ],
      "settings": { "foreground": "#6AAAE0" }
    },
    {
      "name": "JSX component names (PascalCase)",
      "scope": [
        "support.class.component",
        "support.class.component.js",
        "support.class.component.tsx"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },

    {
      "name": "CSS property names",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name",
        "support.type.vendored.property-name.css",
        "meta.property-name.css"
      ],
      "settings": { "foreground": "#C0CFDC" }
    },
    {
      "name": "CSS property values",
      "scope": ["meta.property-value.css", "meta.property-value.scss"],
      "settings": { "foreground": "#85AADF" }
    },
    {
      "name": "CSS keyframe / URL params",
      "scope": [
        "variable.parameter.keyframe-list.css",
        "variable.parameter.url.scss"
      ],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "CSS class & ID selectors",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "variable.parameter.misc.css"
      ],
      "settings": { "foreground": "#6DAEFF" }
    },
    {
      "name": "CSS tag selectors",
      "scope": [
        "source.css.scss entity.name.tag",
        "entity.name.tag.reference.scss",
        "entity.name.tag.nesting.css"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "CSS @-rules and pseudo-classes",
      "scope": [
        "keyword.control.at-rule",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element",
        "source.sass keyword.control"
      ],
      "settings": { "foreground": "#A28CF4" }
    },
    {
      "name": "CSS attribute selectors",
      "scope": [
        "entity.other.attribute-name",
        "meta.property-list.scss",
        "meta.attribute-selector.scss",
        "entity.other.keyframe-offset.css",
        "meta.selector.css",
        "punctuation.separator.key-value.css"
      ],
      "settings": { "foreground": "#7A9AAE" }
    },
    {
      "name": "SCSS variables",
      "scope": ["variable.scss", "variable.sass"],
      "settings": { "foreground": "#85AADF" }
    },

    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#6DAAFF" }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "JSON Key - Level 3+",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#7FE7D0" }
    },

    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": { "foreground": "#849DB0" }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markup.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown",
        "markup.inserted.git_gutter"
      ],
      "settings": { "foreground": "#6DAAFF" }
    },
    {
      "name": "Markup - Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#849DB0" }
    },
    {
      "name": "Markup - Bold",
      "scope": ["markup.bold", "markup.bold string"],
      "settings": { "fontStyle": "bold", "foreground": "#A8BFCF" }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": { "fontStyle": "bold italic", "foreground": "#A8BFCF" }
    },
    {
      "name": "Markup - Underline",
      "scope": ["markup.underline"],
      "settings": { "fontStyle": "underline", "foreground": "#6DAEFF" }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": ["markup.quote punctuation.definition.blockquote.markdown"],
      "settings": { "foreground": "#4E6070" }
    },
    {
      "name": "Markup - Quote",
      "scope": ["markup.quote"],
      "settings": {}
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": { "foreground": "#4EC9E4" }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": { "foreground": "#4E6070" }
    },
    {
      "name": "Markdown - Link",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#6DAAFF" }
    },
    {
      "name": "Markdown - Link Description",
      "scope": ["string.other.link.description.title.markdown"],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": ["constant.other.reference.link.markdown"],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "Markup - Raw Block",
      "scope": ["markup.raw.block"],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "Markdown - Fenced Block",
      "scope": [
        "markup.raw.block.fenced.markdown",
        "variable.language.fenced.markdown",
        "punctuation.definition.fenced.markdown",
        "punctuation.section.class.end"
      ],
      "settings": { "foreground": "#4E6070" }
    },
    {
      "name": "Markdown - Fenced Language",
      "scope": ["variable.language.fenced.markdown"],
      "settings": { "foreground": "#50B0C4" }
    },
    {
      "name": "Markdown - Separator",
      "scope": ["meta.separator"],
      "settings": { "fontStyle": "bold", "foreground": "#4E6070" }
    },
    {
      "name": "Markup - Table",
      "scope": ["markup.table"],
      "settings": { "foreground": "#849DB0" }
    },

    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#7FE7D0" }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#A05870" }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#9D8FD8" }
    },

    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": { "fontStyle": "underline" }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": { "fontStyle": "italic", "foreground": "#50B0C4" }
    },

    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E06C75" }
    },

    {
      "name": "Tag punctuation — < > </ />",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.definition.tag.begin.jsx",
        "punctuation.definition.tag.end.jsx",
        "punctuation.definition.tag.begin.tsx",
        "punctuation.definition.tag.end.tsx"
      ],
      "settings": { "foreground": "#7B8FA0" }
    },

    {
      "name": "Brackets, parens, braces — {} () []",
      "scope": [
        "punctuation.curlybrace.open",
        "punctuation.curlybrace.close",
        "punctuation.parenthesis.open",
        "punctuation.parenthesis.close",
        "punctuation.squarebracket.open",
        "punctuation.squarebracket.close",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly",
        "punctuation.definition.block.begin",
        "punctuation.definition.block.end",
        "punctuation.section.block.begin",
        "punctuation.section.block.end",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.definition.array.begin",
        "punctuation.definition.array.end",
        "punctuation.section.array.begin",
        "punctuation.section.array.end",
        "punctuation.section.function.begin.bracket.round",
        "punctuation.section.function.end.bracket.round",
        "punctuation.section.property-list.begin.bracket.curly.css",
        "punctuation.section.property-list.end.bracket.curly.css",
        "punctuation.section.property-list.begin.bracket.curly.scss",
        "punctuation.section.property-list.end.bracket.curly.scss"
      ],
      "settings": { "foreground": "#7B8FA0" }
    }
  ]
}
